# ============================================================
# Automated Reporting Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.
# ============================================================

# Email delivery via Mailtrap SMTP
EMAIL_SENDER=hello@demomailtrap.co
EMAIL_PASSWORD=your_mailtrap_api_token_here

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_EXPIRE_MINUTES=60

# AI Insights (optional)
# If unset, AI insights fall back to a built-in rule-based generator.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
